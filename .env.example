# ============================================================
# 케이스랩 환경변수 — “돈 0원 출시” 모드 기준 (2026-06-01)
# ============================================================

# ─── 필수 (Day 1 Supabase 가입 후 채움) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── 필수 (Day 10 Vercel 배포 후 채움) ───
# 무료 서브도메인 사용 시: https://caselab.vercel.app (Vercel이 정함)
# 커스텀 도메인 도입 시: https://caselab.kr 같이 변경
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Draft Preview 토큰 (`openssl rand -hex 32`로 생성)
DRAFT_PREVIEW_SECRET=change-this-to-random-32-chars

# ─── 선택 (GA4 — Day 8 출시 직전 활성) ───
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── 선택 (GA4 Data API 읽기 — D33 유입 패널, 서버 전용) ───
# GA4 property → Admin → Property Settings의 숫자 Property ID
GA4_PROPERTY_ID=
# GCP 서비스 계정 Key JSON을 base64로 인코딩한 값 (base64 -i service-account.json)
GA4_SERVICE_ACCOUNT_JSON=

# ─── 선택 (Kakao OAuth — Day 2, Edge Function secret으로도 등록) ───
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ─── 전자책 발송 (Day 9 — Brevo HTTP API, Supabase Edge Function secrets로 등록) ───
# Brevo dashboard → Senders → Add a sender (caselab.kr@gmail.com 단일 발신자 인증)
# Brevo dashboard → SMTP & API → API Keys → Generate (형식: xkeysib-...)
# (Vercel 환경변수에는 등록 안 함. supabase secrets set ... 로만 등록)
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
# BREVO_SENDER_EMAIL=caselab.kr@gmail.com
# BREVO_SENDER_NAME=케이스랩

# ─── 출시 후 도입 (지금은 활성 X) ───
# Anthropic Claude — AI 초안 버튼 도입 시 활성화
# 활성화하려면 두 변수 모두 채우고 NEXT_PUBLIC_AI_DRAFT_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-xxx
# NEXT_PUBLIC_AI_DRAFT_ENABLED=true

# ─── HERMES 씨앗 → 생성 연결 (③ 로컬 작업장 모델) ───
# AI 호출 프로바이더: subscription(기본, 로컬 Claude CLI 구독 OAuth — 토큰비용 0) | apikey(위 ANTHROPIC_API_KEY 사용)
#   로컬 Mac에서 돌릴 땐 subscription, Vercel 폴백이 필요하면 apikey.
# AI_PROVIDER=subscription
# seed triage 화면의 "생성" 버튼은 이 값이 true일 때만 노출 (Claude CLI 있는 로컬에서만). Vercel엔 미설정 → 숨김.
# NEXT_PUBLIC_LOCAL_AI=true
# (선택) launchd 등에서 PATH에 claude가 없을 때 절대경로 지정
# CLAUDE_CLI_PATH=/Users/amanda/.npm-global/bin/claude

# ─── HERMES 브리퍼 → Seed Backlog 자동 적재 (Slack Events 웹훅) ───
# 설정 가이드: etc/slack-hermes-brief-setup.md
# Slack: api.slack.com/apps → hermes 앱 → Basic Information → Signing Secret
# SLACK_SIGNING_SECRET=...
# 대상 채널 (멀티채널). "채널ID:lane" 콤마 목록. lane → source_type 매핑은 lib/seed-sources.ts LANE_SOURCE.
# 소스별 전용 lane(버킷 힌트): ai-briefing(→trend) · service-scout(→service) ·
#   painpoint-youtube/painpoint-community/painpoint-blog/painpoint-instagram(→painpoint). 기타 lane은 slack-brief.
# 소스·수집기준 상세: etc/seed-source-spec.md
# SLACK_HERMES_CHANNELS=<채널ID>:ai-briefing,<채널ID>:service-scout,<채널ID>:painpoint-youtube,<채널ID>:painpoint-community,<채널ID>:painpoint-blog,<채널ID>:painpoint-instagram
#   (구버전 단일 채널: SLACK_HERMES_CHANNEL_ID=C0XXX 도 계속 동작 — lane "slack" → source_type "slack-brief")
# ※ 봇 메시지(크론 브리핑)만 적재하고 사람 수동 대화는 자동 제외됨.
# ※ 각 채널에 @caselab-brief-listener 봇이 초대돼 있어야 함.
# Notion: notion.so/my-integrations → 내부 통합 토큰(ntn_...), Seed Backlog DB를 통합에 Connections로 연결
# NOTION_TOKEN=ntn_xxx
# NOTION_SEED_DB_ID=c5b293982e854db2940211c861c50112
